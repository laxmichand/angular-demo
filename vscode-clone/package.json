{
  "name": "vscode-clone",
  "version": "1.0.0",
  "description": "Production-ready Visual Studio Code clone built with Angular",
  "author": "Laxmi Chand",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve --open",
    "build": "ng build",
    "build:prod": "ng build --prod --aot --build-optimizer --stats-json",
    "test": "ng test",
    "test:ci": "ng test --watch=false --code-coverage --browsers=ChromeHeadless",
    "e2e": "ng e2e",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "analyze": "webpack-bundle-analyzer dist/vscode-clone/stats.json",
    "docker:build": "docker build -t vscode-clone:latest .",
    "docker:run": "docker run -p 3000:80 vscode-clone:latest"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@ngrx/effects": "^18.0.0",
    "@ngrx/store": "^18.0.0",
    "@ngrx/store-devtools": "^18.0.0",
    "@ngrx/router-store": "^18.0.0",
    "@monaco-editor/loader": "^1.4.0",
    "monaco-editor": "^0.50.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.7.0",
    "zone.js": "^0.15.0",
    "highlight.js": "^11.10.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.14.0",
    "ngx-virtual-scroller": "^16.0.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@types/jasmine": "^5.1.0",
    "@types/node": "^20.0.0",
    "jasmine-core": "^5.1.0",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.0",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "typescript": "~5.6.0",
    "prettier": "^3.1.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "webpack-bundle-analyzer": "^4.10.0",
    "@ngrx/schematics": "^18.0.0"
  }
}
